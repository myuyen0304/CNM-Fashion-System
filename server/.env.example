# MongoDB
# MONGO_URI=mongodb://localhost:27017/eshop

# MongoDB Atlas

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<app-name>

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_REFRESH_EXPIRE=30d

# Cloudinary
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@eshop.com

# VNPay
# VNPAY_RETURN_URL phải trỏ về callback API của server.
# Code hiện hỗ trợ cả VNPAY_TMN_CODE/VNPAY_URL và alias cũ VNPAY_MERCHANT_ID/VNPAY_API_URL.
VNPAY_TMN_CODE=your_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/api/payments/vnpay/callback

# App
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

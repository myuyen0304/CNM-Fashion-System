# MongoDB Atlas example:
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<app-name>

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_COOKIE_NAME=refreshToken

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI chatbot
DEEPSEEK_API_KEY=your_deepseek_api_key

# Email
# Render Free blocks outbound SMTP ports 25/465/587. Use resend or gmail-api
# on Render if you need real delivery without upgrading the Render instance.
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@eshop.com
EMAIL_SEND_TIMEOUT_MS=8000
ALLOW_DEMO_OTP_FALLBACK=false

# Required when EMAIL_PROVIDER=gmail-api
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_google_oauth_refresh_token

# Required when EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key

# VNPay
# VNPAY_RETURN_URL phải trỏ về callback API của server.
# Code hiện hỗ trợ cả VNPAY_TMN_CODE/VNPAY_URL và alias cũ VNPAY_MERCHANT_ID/VNPAY_API_URL.
VNPAY_TMN_CODE=your_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/api/payments/vnpay/callback
VNPAY_TIMEZONE=Asia/Ho_Chi_Minh

# App
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
